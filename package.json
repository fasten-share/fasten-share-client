{
  "name": "fasten-share-client",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env FS_WS_PORT=8087 next dev -p 8086",
    "build": "next build",
    "start": "cross-env FS_WS_PORT=8087 next start -p 8086",
    "start2": "cross-env FS_WS_PORT=8027 next start -p 8026",
    "start3": "cross-env FS_WS_PORT=8037 next start -p 8036",
    "lint": "eslint",
    "export:desktop": "next build && shx cp -r .next/static .next/standalone/.next/static && shx cp -r public .next/standalone/public && shx rm -rf ../fasten-share-desktop/server-dist && shx cp -r .next/standalone ../fasten-share-desktop/server-dist"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "json5": "^2.2.3",
    "next": "16.2.9",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "ws": "^8.18.0",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.5.12",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "shx": "^0.4.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
